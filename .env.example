# WRDS — Wharton Research Data Services
# Sign up at wrds-www.wharton.upenn.edu; password is prompted on first run and cached in .pgpass
WRDS_USER=your_wrds_username

# FRED — St. Louis Fed
# Free key at fredaccount.stlouisfed.org/apikeys
# Alternatively, place the key in a one-line file at repo root: fred_api_key.txt (gitignored)
FRED_API_KEY=your_fred_api_key
